# Database Configuration
# PostgreSQL connection string for user accounts, ratings, and session data
DATABASE_URL=postgresql://scentscape:scentscape_password@localhost:5432/scentscape

# Neo4j Knowledge Graph
# URI to Neo4j instance (AuraDB in production, local container for dev)
NEO4J_URI=neo4j://localhost:7687
# Neo4j authentication credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Redis
# Redis connection URL for Celery broker and caching (recommendations cached 24h)
REDIS_URL=redis://localhost:6379/0

# Vector Database (Pinecone)
# Pinecone API key for fragrance embedding storage and ANN similarity search
PINECONE_API_KEY=your_pinecone_api_key_here
# Pinecone environment (e.g., us-west4-gcp)
PINECONE_ENVIRONMENT=us-west4-gcp
# Pinecone index name (dimension: 128, metric: cosine)
PINECONE_INDEX_NAME=scentscape-fragrances

# Authentication
# Secret key for JWT token signing/verification (generate with openssl rand -hex 32)
JWT_SECRET_KEY=your_secret_key_here_minimum_32_chars

# Error Tracking
# Sentry DSN for error and performance monitoring in production
SENTRY_DSN=https://your_sentry_key@sentry.io/project_id
# Sentry environment tag (development, staging, production)
SENTRY_ENVIRONMENT=development
# Sentry traces sample rate (0.1 = 10% of transactions sampled for performance monitoring)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Object Storage (Cloudflare R2)
# Cloudflare R2 access key for raw data storage (Fragrantica scrapes, embeddings backup)
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key_here
# Cloudflare R2 secret key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key_here
# Cloudflare R2 bucket name
CLOUDFLARE_R2_BUCKET=scentscape-data
# Cloudflare R2 endpoint URL
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Frontend
# Next.js API base URL (backend endpoint, used in browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feature Flags
# Enable gender-neutral recommendation mode (default: true, recommended: never disable)
GENDER_NEUTRAL_RECOMMENDATIONS=true
